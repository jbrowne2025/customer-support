ANTHROPIC_API_KEY=sk-ant-...
PORT=8787

# Supabase - backs the lookup_order tool (live order status lookups).
# Table columns expected: order_number, order_status, order_amount,
# order_primary_email, order_date_time, created_at.
#
# The orders table has RLS enabled, so use the service_role key (Settings ->
# API -> service_role in the Supabase dashboard) - this server never exposes
# it to the browser, so it's safe here. Never put a service_role key in
# client-side code.
#
# IMPORTANT: this file is a tracked template. Put PLACEHOLDER values only.
# Real secrets go in server/.env, which is gitignored and never committed -
# it will never show up in GitHub's file browser, on any branch. That's
# intentional, not a bug: create it locally (`cp .env.example .env`) or set
# these as environment variables directly wherever you deploy the server.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ORDERS_TABLE=orders

